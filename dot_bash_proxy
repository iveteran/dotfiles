# vim: set ft=sh

export no_proxy="localhost, 127.0.0.1, 163.com, 172.20.10.11/28, 192.168.8.0/24"

HOST=127.0.0.1

proxy_on() {
    export http_proxy="http://${HOST}:7890"
    export https_proxy="http://${HOST}:7890"
    export socks_proxy="${HOST}:7891"
    if command -v javac &> /dev/null; then
        export JAVA_OPT="-Dhttps.proxyPort=7890 -Dhttps.proxyHost=127.0.0.1"
    fi

    proxy_show
}

# clear proxies
proxy_off() {
    unset http_proxy
    unset https_proxy
    unset socks_proxy

    proxy_show
}

proxy_show() {
    # show proxy settings
    env | grep -i proxy
}
