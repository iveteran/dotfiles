# .bash_profile

# Get the aliases and functions
if [ -f ~/.bashrc ]; then
	. ~/.bashrc
fi

#if [[ "$TERM" = "linux" && -e `which fbterm` ]]; then
#    fbterm
#fi

set -o ignoreeof # Prevent Ctrl-D to exit shell
set -o vi
stty -ixon  # Enable searching history in Bash forward after backward with CTRL-S

# User specific environment and startup programs

export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

#command_exists starship && eval "$(starship init bash)"

[[ -f ~/.bash_prompt ]] && source ~/.bash_prompt
[[ -f ~/.bash_aliases ]] && source ~/.bash_aliases
[[ -f ~/.bash_bindings ]] && source ~/.bash_bindings
[[ -f ~/.bash_functions ]] && source ~/.bash_functions
[[ -f ~/.less_termcap ]] && source ~/.less_termcap
[[ -f ~/.bash_proxy ]] && source ~/.bash_proxy
[[ -f ~/.fzfrc.sh ]] && source ~/.fzfrc.sh

# enable Proxy, the function defined in ~/.bash_proxy
#proxy_on

export EDITOR='vim'
export PAGER='less'
#export PAGER='most'

export HISTTIMEFORMAT='[%F %T] '
#export HISTCONTROL=ignorespace
#export HISTCONTROL=ignoredups
export HISTCONTROL=ignoreboth # both ignore space and dups

export SYSTEMD_EDITOR='vim'
export PSQL_EDITOR="vim -c 'set syntax=sql'"

# GnuPG
export GPG_TTY=$(tty)

# Enable use GUI apps on WSL by VcXsrv for Windows 10
# Refers:
#   1) https://techcommunity.microsoft.com/t5/windows-dev-appconsult/running-wsl-gui-apps-on-windows-10/ba-p/1493242
#   2) https://sourceforge.net/projects/vcxsrv/
#export DISPLAY="`grep nameserver /etc/resolv.conf | sed 's/nameserver //'`:0"
#export DISPLAY=":0"

PATH=$PATH:/sbin:/usr/sbin:/snap/bin
[[ -d $HOME/.local/bin ]] && PATH=$PATH:$HOME/.local/bin

# AppImage
[ -d /opt/AppImage ] && PATH=$PATH:/opt/AppImage

# Snap
[[ -d /snap ]] && PATH=$PATH:/snap/bin

# Rust environment
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"
if command_exists rustup; then
    # Rust mirror environment
    export RUSTUP_DIST_SERVER=https://mirrors.ustc.edu.cn/rust-static
    export RUSTUP_UPDATE_ROOT=https://ustc.edu.cn
    export CARGO_HTTP_CACHING=false
fi

# Keychian
if [[ -f $HOME/.ssh/iv.id_rsa ]] && command_exists keychain; then
    eval "$(keychain --eval --quiet "$HOME/.ssh/iv.id_rsa")"
fi

# x-cmd
# Repo: https://github.com/x-cmd/x-cmd
# Install: eval "$(curl https://get.x-cmd.com)"
x_on() {
    [ -f "$HOME/.x-cmd.root/X" ] && . "$HOME/.x-cmd.root/X" # boot up x-cmd.
    #source ~/.bash_prompt
}
#x_on  # Enable x-cmd

# Enable zoxide - A smarter cd command
# Install: cargo install zoxide OR apt install zoxide
command_exists zoxide && eval "$(zoxide init bash)"

# khal
command_exists khal && eval "$(_KHAL_COMPLETE=bash_source khal)"

# MPD daemon start (if no other user instance exists)
if command_exists mpd; then
    [[ ! -s ~/.mpd/pid ]] && mpd
fi

# Tmuxifier
if [[ -d $HOME/.tmuxifier ]]; then
    # git clone https://github.com/jimeh/tmuxifier.git ~/.tmuxifier
    PATH=$PATH:$HOME/.tmuxifier/bin
elif [[ -d $HOME/.tmux/plugins/tmuxifier ]]; then
    PATH=$PATH:$HOME/.tmux/plugins/tmuxifier/bin
fi
if command_exists tmuxifier; then
    eval "$(tmuxifier init -)"
    [[ ! -d ~/.tmux-layouts ]] && mkdir ~/.tmux-layouts
    export TMUXIFIER_LAYOUT_PATH="$HOME/.tmux-layouts"
fi

# Node environment by manually
NODE_ROOT="/opt/node"
[ -d $NODE_ROOT ] && PATH=$PATH:$NODE_ROOT/bin

# Node 3rd-party modules installation path
NODE_MODULES_ROOT="$HOME/node_modules"
[ -d $NODE_MODULES_ROOT ] && PATH=$PATH:$NODE_MODULES_ROOT/.bin

# nvm - Node Version Manager
NVM_DIR="$HOME/.nvm"
if [[ -d $NVM_DIR ]]; then
    export NVM_DIR
    . $NVM_DIR/nvm.sh  # This loads nvm
    . $NVM_DIR/bash_completion  # This loads nvm bash_completion
fi

# fnm - Fast Node Manager, another node version manager
# fnm - add fnm path (for Linux)
FNM_PATH="$HOME/.local/share/fnm"
if [ -d "$FNM_PATH" ]; then
    PATH="$FNM_PATH:$PATH"
fi
# fnm - env setup
if command_exists fnm; then
    eval "$(fnm env --use-on-cd --shell bash)"
fi

# Flutter
[ -d $HOME/Flutter/flutter ] && PATH=$PATH:$HOME/Flutter/flutter/bin
[ -d $HOME/develop/flutter ] && PATH=$PATH:$HOME/develop/flutter/bin

# Zig
[ -d /opt/zig ] && PATH=$PATH:/opt/zig

# Conda
[ -f /opt/conda/etc/profile.d/conda.sh ] && source /opt/conda/etc/profile.d/conda.sh

# Golang
GO_HOME=/opt/go
if [[ -d $GO_HOME ]]; then
    PATH=$PATH:$GO_HOME/bin
    GOPATH=/opt/$USER/go
    [[ -d $GOPATH ]] && PATH=$PATH:$GOPATH/bin && export GOPATH

    # ķģŹńĮ« GOPROXY ńÄ»ÕóāÕÅśķćÅ
    #export GOPROXY=https://proxy.golang.com.cn,direct
    #export GOPROXY=https://jp.iveteran.me:4433,direct
    # # Ķ┐śÕÅ»õ╗źĶ«ŠńĮ«õĖŹĶĄ░ proxy ńÜäń¦üµ£ēõ╗ōÕ║ōµł¢ń╗ä’╝īÕżÜõĖ¬ńö©ķĆŚÕÅĘńøĖķÜö’╝łÕÅ»ķĆē’╝ē
    # export GOPRIVATE=git.mycompany.com,github.com/my/private
fi

# Homebrew (Mac OS)
HOMEBREW_PATH="/opt/homebrew"
if [ -d "$HOMEBREW_PATH" ]; then
    PATH=$PATH:$HOMEBREW_PATH/bin:$HOMEBREW_PATH/opt/ruby/bin
    source "$HOMEBREW_PATH/etc/profile.d/bash_completion.sh"

    # õĮ┐ńö©Aliyun HomebrewķĢ£ÕāÅ
    export HOMEBREW_INSTALL_FROM_API=1
    export HOMEBREW_API_DOMAIN="https://mirrors.aliyun.com/homebrew-bottles/api"
    export HOMEBREW_BREW_GIT_REMOTE="https://mirrors.aliyun.com/homebrew/brew.git"
    export HOMEBREW_CORE_GIT_REMOTE="https://mirrors.aliyun.com/homebrew/homebrew-core.git"
    export HOMEBREW_BOTTLE_DOMAIN="https://mirrors.aliyun.com/homebrew/homebrew-bottles"
    # using `brew update` to effect settings
fi

# Android SDK
ANDROID_SDK_ROOT="/opt/Android/SDK"
if [[ -d $ANDROID_SDK_ROOT ]]; then
    export ANDROID_SDK_ROOT
    PATH=$PATH:$ANDROID_SDK_ROOT/emulator
    PATH=$PATH:$ANDROID_SDK_ROOT/cmdline-tools/latest/bin/
    PATH=$PATH:$ANDROID_SDK_ROOT/platform-tools
    PATH=$PATH:$ANDROID_SDK_ROOT/build-tools/34.0.0

    NDK_ROOT=$ANDROID_SDK_ROOT/ndk/25.2.9519653
    if [[ -d $NDK_ROOT ]]; then
        export NDK_ROOT
        PATH=$NDK_ROOT:$PATH
    fi
fi

# Android command-line tools
ANDROID_CMDLINE_ROOT="/opt/android-cmdline-tools"
[ -d $ANDROID_CMDLINE_ROOT ] && PATH=$PATH:$ANDROID_CMDLINE_ROOT/bin

# Android Studio
ANDROID_STUDIO_ROOT="/opt/android-studio"
if [[ -d $ANDROID_STUDIO_ROOT ]]; then
    PATH=$PATH:$ANDROID_STUDIO_ROOT/bin
    JAVA_HOME="$ANDROID_STUDIO_ROOT/jbr"
    export JAVA_HOME
    PATH=$PATH:$JAVA_HOME/bin
fi

# Pyenv
PYENV_ROOT="$HOME/.pyenv"
if [[ -d $PYENV_ROOT ]]; then
    export PYENV_ROOT
    PATH=$PATH:$PYENV_ROOT/bin
    eval "$(pyenv init -)"
fi

# Dotnet on Windows (For running Dotnet on WSL or Bash for Windows)
dotnet_path=/mnt/c/Program\ Files/dotnet
[ -d "$dotnet_path" ] && PATH=$PATH:"$dotnet_path"

# export all PATH
export PATH
